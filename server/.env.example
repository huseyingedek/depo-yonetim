# Backend proxy ortam değişkenleri ÖRNEĞİ.
# Kopyala:  cp server/.env.example server/.env  ve gerçek değerleri doldur.
# server/.env git'e GİRMEZ; şifreler yalnızca burada durur, tarayıcıya inmez.

PORT=8787

# --- CANIAS SOAP servisi ---
# WSDL adresi (Aktüel VPN gerekir)
# Sürüm: v1 = args virgülle (önerilen), v2 = Parameters XML
CANIAS_WS_VERSION=v1
CANIAS_WSDL_URL=http://192.168.22.16:8080/CaniasWS-v1/services/iasWebService?wsdl

# WS kullanıcısı
WMS_USER=WMSWSUSER
WMS_PASSWORD=

# --- CANIAS login parametreleri ---
CANIAS_CLIENT=00
CANIAS_LANGUAGE=T
CANIAS_DBSERVER=CANIAS
CANIAS_DBNAME=AKTUEL
# DİKKAT: port zorunlu (:27499) — portsuz yazılırsa login "iasClientManager" hatası verir
CANIAS_APPSERVER=192.168.22.16:27499

# Frontend origin (CORS). Birden fazla ise virgülle ayır.
CORS_ORIGIN=http://localhost:5173

# --- Sadece test/keşif scriptleri içindir, uygulama kullanmaz ---
T_COMPANY=01
T_PLANT=100
T_WAREHOUSE=D1
T_ORDERNUM=
T_ORDERTYPE=
T_BARCODE=
